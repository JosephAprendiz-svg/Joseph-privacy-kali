#!/bin/bash
V='\033[0;32m'
R='\033[0;31m'
A='\033[1;33m'
C='\033[0;36m'
NC='\033[0m'

clear
echo "================================================"
echo "   JOSEPH TRIO POTENTE - EDICION MAESTRO"
echo "   Mullvad + Tor + Proxychains + KillSwitch"
echo "================================================"
echo ""
echo "  Selecciona una opcion:"
echo ""
echo "  1) Modo Privacidad      - Solo Mullvad"
echo "  2) Modo Anonimo Total   - Mullvad + Tor + Proxychains"
echo "  3) Nueva identidad Tor  - Cambiar IP"
echo "  4) Kill Switch ON"
echo "  5) Kill Switch OFF"
echo "  6) Test de seguridad"
echo "  7) Apagar todo"
echo ""
read -p "Elige opcion (1-7): " OPCION
echo ""

if [ "$OPCION" = "1" ]; then
    echo "Activando Mullvad..."
    mullvad connect
    sleep 4
    mullvad status
elif [ "$OPCION" = "2" ]; then
    echo "Activando Mullvad..."
    mullvad connect
    sleep 4
    echo "Levantando Tor..."
    systemctl start tor
    sleep 5
    echo "Verificando salida Tor..."
    proxychains4 -q curl -s --max-time 20 https://check.torproject.org/api/ip
    echo ""
    echo "TRIO POTENTE ACTIVO"
elif [ "$$OPCION" = "3" ]; then
    printf 'authenticate ""\nsignal newnym\nquit\n' | nc 127.0.0.1 9051 > /dev/null 2>&1
    sleep 5
    proxychains4 -q curl -s --max-time 20 https://check.torproject.org/api/ip
    echo ""
elif [ "$$OPCION" = "4" ]; then
    mullvad lockdown-mode set on
    echo "Kill Switch ON"
elif [ "$$OPCION" = "5" ]; then
    mullvad lockdown-mode set off
    echo "Kill Switch OFF"
elif [ "$$OPCION" = "6" ]; then
    curl -s --max-time 10 https://api.ipify.org
    echo ""
    mullvad status
    systemctl is-active tor
    curl -s --max-time 10 https://am.i.mullvad.net/json
    echo ""
elif [ "$OPCION" = "7" ]; then
    systemctl stop tor
    mullvad disconnect
    echo "Todo desconectado"
else
    echo "Opcion invalida"
fi
